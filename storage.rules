rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // =========================================================
    //  SELFIES FOLDER
    //  - Anyone can upload to selfies/{userId}/... (public game)
    //  - Only authenticated admin can read, delete
    //  - Max file size: 10MB
    //  - Only image content types allowed
    // =========================================================
    match /selfies/{userId}/{allPaths=**} {
      allow create: if request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow read, delete: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
